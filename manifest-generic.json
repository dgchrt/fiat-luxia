{
  "manifest_version": 3,
  "name": "Fiat Luxia",
  "version": "1.0.0",
  "description": "Restores light to the dark corners of the web.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "128": "icon.png" }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": { "128": "icon.png" }
}
